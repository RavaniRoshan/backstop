{
  "title": "Backstop LLM Guardrails",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["backstop", "llm", "budgets"],
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests By Outcome",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (outcome) (rate(backstop_requests_total[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Remaining Budget",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "backstop_budget_remaining_tokens",
          "legendFormat": "tokens"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Circuit State",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "backstop_circuit_state",
          "legendFormat": "closed=0 half_open=1 open=2"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue Wait p95",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 4},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, priority) (rate(backstop_queue_wait_seconds_bucket[5m])))",
          "legendFormat": "{{priority}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Duration p95",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint, priority) (rate(backstop_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{endpoint}} {{priority}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Retries And Circuit Trips",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(backstop_retry_attempts_total[5m]))",
          "legendFormat": "retries"
        },
        {
          "expr": "sum(rate(backstop_circuit_trips_total[5m]))",
          "legendFormat": "circuit trips"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache Hits And Budget Blocks",
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(backstop_cache_hits_total[5m]))",
          "legendFormat": "cache hits"
        },
        {
          "expr": "sum(rate(backstop_budget_exceeded_total[5m]))",
          "legendFormat": "budget blocks"
        },
        {
          "expr": "sum(rate(backstop_tenant_budget_exceeded_total[5m]))",
          "legendFormat": "tenant budget blocks"
        }
      ]
    }
  ]
}
